# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env (commit .env.example; keep secrets local)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Prisma generated client — recreated by `postinstall`, `npm run dev`, and `npm run build`.
# If you see PrismaClientValidationError on new schema fields, run: npx prisma generate
/generated/

# vercel
.vercel

# local file uploads (CV originals — not committed)
/uploads/cv/*.pdf
/uploads/cv/*.doc
/uploads/cv/*.docx
/uploads/cv/*.txt

# typescript
*.tsbuildinfo
next-env.d.ts
