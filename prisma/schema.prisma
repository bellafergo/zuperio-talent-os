// Zuperio Talent OS — database schema (foundation)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ------------------------------------------------------------------

enum CompanyStatus {
  ACTIVE
  PROSPECT
  PAUSED
  CHURNED
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ContactStatus {
  ACTIVE
  INACTIVE
}

enum VacancySeniority {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
  PRINCIPAL
}

enum VacancyStatus {
  DRAFT
  OPEN
  ON_HOLD
  SOURCING
  INTERVIEWING
  FILLED
  CANCELLED
}

enum CandidateAvailabilityStatus {
  AVAILABLE
  IN_PROCESS
  ASSIGNED
  NOT_AVAILABLE
}

// --- Models -----------------------------------------------------------------
// Auth/session fields can be added later; this is an internal-directory shape.

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companiesAsOwner    Company[]     @relation("CompanyOwner")
  opportunitiesAsOwner Opportunity[] @relation("OpportunityOwner")
}

model Company {
  id        String        @id @default(cuid())
  name      String
  industry  String?
  location  String?
  status    CompanyStatus @default(PROSPECT)

  ownerId String?
  owner   User?   @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contacts      Contact[]
  opportunities Opportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
}

model Contact {
  id        String        @id @default(cuid())
  firstName String
  lastName  String?
  email     String?
  phone     String?
  title     String?
  status    ContactStatus @default(ACTIVE)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([email])
}

model Opportunity {
  id    String             @id @default(cuid())
  title String
  stage OpportunityStage   @default(PROSPECTING)
  /// Monetary value in major currency units (e.g. euros); refine precision later if needed.
  value Decimal?           @db.Decimal(14, 2)
  currency String?         @default("EUR")

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ownerId String?
  owner   User?   @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  vacancies Vacancy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([stage])
  @@index([ownerId])
}

model Vacancy {
  id        String           @id @default(cuid())
  title     String
  seniority VacancySeniority
  status    VacancyStatus    @default(OPEN)
  /// Target bill rate (e.g. per hour) in major currency units.
  targetRate Decimal?        @db.Decimal(14, 2)
  currency   String?         @default("EUR")

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([opportunityId])
  @@index([status])
  @@index([seniority])
}

/// Staff-augmentation talent pool member (no Vacancy relation yet).
model Candidate {
  id                   String                      @id @default(cuid())
  firstName            String
  lastName             String
  email                String?
  phone                String?
  role                 String
  seniority            VacancySeniority
  /// Comma-separated skills for now (e.g. "React, Node.js, TypeScript").
  skills               String
  availabilityStatus   CandidateAvailabilityStatus @default(AVAILABLE)
  currentCompany       String?
  notes                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seniority])
  @@index([availabilityStatus])
  @@index([email])
}
