// Zuperio Talent OS — database schema (foundation)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ------------------------------------------------------------------

enum CompanyStatus {
  ACTIVE
  PROSPECT
  PAUSED
  CHURNED
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ContactStatus {
  ACTIVE
  INACTIVE
}

// --- Models -----------------------------------------------------------------
// Auth/session fields can be added later; this is an internal-directory shape.

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companiesAsOwner    Company[]     @relation("CompanyOwner")
  opportunitiesAsOwner Opportunity[] @relation("OpportunityOwner")
}

model Company {
  id        String        @id @default(cuid())
  name      String
  industry  String?
  location  String?
  status    CompanyStatus @default(PROSPECT)

  ownerId String?
  owner   User?   @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contacts      Contact[]
  opportunities Opportunity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
}

model Contact {
  id        String        @id @default(cuid())
  firstName String
  lastName  String?
  email     String?
  phone     String?
  title     String?
  status    ContactStatus @default(ACTIVE)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([email])
}

model Opportunity {
  id    String             @id @default(cuid())
  title String
  stage OpportunityStage   @default(PROSPECTING)
  /// Monetary value in major currency units (e.g. euros); refine precision later if needed.
  value Decimal?           @db.Decimal(14, 2)
  currency String?         @default("EUR")

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ownerId String?
  owner   User?   @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([stage])
  @@index([ownerId])
}
