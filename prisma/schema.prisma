// Zuperio Talent OS — database schema (foundation)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ------------------------------------------------------------------

enum CompanyStatus {
  ACTIVE
  PROSPECT
  PAUSED
  CHURNED
}

enum OpportunityStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ContactStatus {
  ACTIVE
  INACTIVE
}

enum VacancySeniority {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
  PRINCIPAL
}

enum VacancyStatus {
  DRAFT
  OPEN
  ON_HOLD
  SOURCING
  INTERVIEWING
  FILLED
  CANCELLED
}

enum CandidateAvailabilityStatus {
  AVAILABLE
  IN_PROCESS
  ASSIGNED
  NOT_AVAILABLE
}

enum MatchRecommendation {
  STRONG_MATCH
  PARTIAL_MATCH
  LOW_MATCH
}

enum PlacementStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// --- Models -----------------------------------------------------------------
// Auth/session fields can be added later; this is an internal-directory shape.

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companiesAsOwner    Company[]     @relation("CompanyOwner")
  opportunitiesAsOwner Opportunity[] @relation("OpportunityOwner")
}

model Company {
  id        String        @id @default(cuid())
  name      String
  industry  String?
  location  String?
  status    CompanyStatus @default(PROSPECT)

  ownerId String?
  owner   User?   @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  contacts      Contact[]
  opportunities Opportunity[]
  placements    Placement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([status])
}

model Contact {
  id        String        @id @default(cuid())
  firstName String
  lastName  String?
  email     String?
  phone     String?
  title     String?
  status    ContactStatus @default(ACTIVE)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([email])
}

model Opportunity {
  id    String             @id @default(cuid())
  title String
  stage OpportunityStage   @default(PROSPECTING)
  /// Monetary value in major currency units (e.g. euros); refine precision later if needed.
  value Decimal?           @db.Decimal(14, 2)
  currency String?         @default("EUR")

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ownerId String?
  owner   User?   @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  vacancies Vacancy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([stage])
  @@index([ownerId])
}

model Vacancy {
  id        String           @id @default(cuid())
  title     String
  seniority VacancySeniority
  status    VacancyStatus    @default(OPEN)
  /// Target bill rate (e.g. per hour) in major currency units.
  targetRate Decimal?        @db.Decimal(14, 2)
  currency   String?         @default("EUR")
  /// Comma-separated must-have / nice-to-have skills (matching v1).
  skills       String?
  /// Short role scope for matching and future JD text.
  roleSummary  String?

  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  candidateMatches CandidateVacancyMatch[]
  placements       Placement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([opportunityId])
  @@index([status])
  @@index([seniority])
}

/// Staff-augmentation talent pool member.
model Candidate {
  id                   String                      @id @default(cuid())
  firstName            String
  lastName             String
  email                String?
  phone                String?
  role                 String
  seniority            VacancySeniority
  /// Comma-separated skills for now (e.g. "React, Node.js, TypeScript").
  skills               String
  availabilityStatus   CandidateAvailabilityStatus @default(AVAILABLE)
  currentCompany       String?
  notes                String?

  vacancyMatches CandidateVacancyMatch[]
  placements     Placement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seniority])
  @@index([availabilityStatus])
  @@index([email])
}

/// Staff augmentation assignment: candidate delivering work for a client via a vacancy.
model Placement {
  id        String @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  vacancyId   String
  vacancy     Vacancy   @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  /// Client account (denormalized for fast lookups; should match vacancy.opportunity.company).
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  startDate DateTime
  endDate   DateTime?
  status    PlacementStatus

  /// Bill rate to client (major currency units, e.g. per hour).
  rateClient    Decimal? @db.Decimal(14, 2)
  /// Pay rate to candidate (major currency units, e.g. per hour).
  rateCandidate Decimal? @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([candidateId])
  @@index([vacancyId])
  @@index([status])
}

/// Deterministic staff-augmentation match (v1); recomputed from rules + seed sync.
model CandidateVacancyMatch {
  id                  String              @id @default(cuid())
  candidateId         String
  candidate           Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  vacancyId           String
  vacancy             Vacancy             @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  score               Int
  seniorityMatch      Boolean
  availabilityMatch   Boolean
  skillsMatchNotes    String?
  recommendation      MatchRecommendation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([candidateId, vacancyId])
  @@index([vacancyId])
  @@index([candidateId])
  @@index([score])
}
