# Copy to .env and adjust for your PostgreSQL instance.
# Prisma CLI reads this via prisma.config.ts (dotenv).

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/zuperio_talent_os?schema=public"

# NextAuth / Auth.js — required for sign-in (generate: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# Optional; inferred in dev from request URL when unset
# AUTH_URL="http://localhost:3000"

# Optional: password for all seed users (default: changeme)
# AUTH_SEED_PASSWORD="changeme"

# PDF generation via Puppeteer — Chromium executable path.
# Required when Puppeteer's bundled Chromium is not downloaded (common in CI and fresh installs).
# macOS (Google Chrome): /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# macOS (Chromium):      /Applications/Chromium.app/Contents/MacOS/Chromium
# Linux (CI, Railway):   /usr/bin/google-chrome-stable   or   /usr/bin/chromium-browser
# To use Puppeteer's bundled Chromium instead, run: npx puppeteer browsers install chrome
# PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# Optional: OpenAI for “Generar preguntas con IA” on vacancy interview prep (server-side only).
# OPENAI_API_KEY=”sk-...”
# OPENAI_INTERVIEW_MODEL=”gpt-4o-mini”

# Optional: Anthropic Claude for AI features on candidate detail page
# (CV highlight analysis + personalized interview questions).
# ANTHROPIC_API_KEY=”sk-ant-...”
